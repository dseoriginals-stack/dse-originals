generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id             String      @id @default(uuid())
  name           String
  email          String      @unique
  password       String?
  provider       String      @default("local")
  address        String?
  phone          String?
  role           Role        @default(customer)
  luckyPoints    Int         @default(0)
  lifetimePoints Int         @default(0)
  tier           LoyaltyTier @default(Faith)
  emailVerified  Boolean     @default(true)
  // referralCode   String?     @unique
  // referredById   String?
  createdAt      DateTime    @default(now())

  // shopId String?

  carts Cart[]

  // ✅ MAIN USER ORDERS
  orders Order[] @relation("UserOrders")

  // ✅ STAFF TRACKING
  approvedOrders  Order[] @relation("ApprovedBy")
  shippedOrders   Order[] @relation("ShippedBy")
  deliveredOrders Order[] @relation("DeliveredBy")

  refreshTokens RefreshToken[]
  stories       Story[]
  reviews       Review[]
  wishlists     Wishlist[]
  addresses     Address[]
  donations     Donation[]

  // ✅ REFERRALS
  // referrals     Referral[] @relation("Referrer")
  // referredBy    Referral[] @relation("Referee")

  @@index([email])
  // @@index([referralCode])
  // @@index([shopId])
}

