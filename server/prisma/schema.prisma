model EmailVerificationToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

//////////////////////////////////////////////////////
// ADDRESS
//////////////////////////////////////////////////////

model Address {
  id     String  @id @default(uuid())
  userId String
  label  String? // Home, Office

  fullName String
  phone    String

  region     String
  province   String
  city       String
  barangay   String
  street     String
  postalCode String?

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

//////////////////////////////////////////////////////
// OrderAddress
//////////////////////////////////////////////////////

model OrderAddress {
  id      String @id @default(uuid())
  orderId String @unique

  fullName   String
  phone      String
  region     String
  province   String
  city       String
  barangay   String
  street     String
  postalCode String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////
// CATEGORIES
//////////////////////////////////////////////////////

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  products Product[]
}

//////////////////////////////////////////////////////
// PRODUCTS
//////////////////////////////////////////////////////

model Product {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?

  status ProductStatus @default(active)

  videoUrl     String?
  storyHtml    String?
  isBestseller Boolean @default(false)
  isPopular    Boolean @default(false)

  metaTitle       String?
  metaDescription String?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images   ProductImage[]
  variants ProductVariant[]

  reviews   Review[]
  wishlists Wishlist[]

  @@index([slug])
  @@index([categoryId])
  @@index([name])
}

//////////////////////////////////////////////////////
// PRODUCT IMAGES
//////////////////////////////////////////////////////

model ProductImage {
  id        String @id @default(uuid())
  productId String
  url       String

  position  Int     @default(0)
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

//////////////////////////////////////////////////////
// PRODUCT VARIANTS
//////////////////////////////////////////////////////

model ProductVariant {
  id        String @id @default(uuid())
  productId String

  sku  String  @unique
  name String?

  price         Decimal @db.Decimal(10, 2)
  resellerPrice Decimal @default(0) @db.Decimal(10, 2)
  stock         Int     @default(0)
  image         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  attributes VariantAttribute[]

  orderItems            OrderItem[]
  inventoryReservations InventoryReservation[]
  inventoryMovements    InventoryMovement[]
  cartItems             CartItem[]

  @@index([productId])
}

//////////////////////////////////////////////////////
// VARIANT ATTRIBUTES
//////////////////////////////////////////////////////

model VariantAttribute {
  id        String @id @default(uuid())
  variantId String

  name  String
  value String

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
}

//////////////////////////////////////////////////////
// ORDERS
//////////////////////////////////////////////////////

model Order {
  id         String  @id @default(uuid())
  userId     String?
  guestEmail String?
  guestName  String?

  totalAmount     Decimal   @db.Decimal(10, 2)
  shippingFee     Decimal   @default(0)
  pointsUsed      Int       @default(0)
  pointsDiscount  Decimal   @default(0) @db.Decimal(10, 2)
  deliveryMethod  String
  pickupTime     DateTime?

  paymentId      String?     @unique
  clientOrderId  String?     @unique
  paymentMethod  String?     // cash, online
  isManual       Boolean     @default(false)
  trackingNo     String?
  status         OrderStatus @default(pending)
  // shopId     String?

  // ✅ STAFF TRACKING
  approvedById  String?
  shippedById   String?
  deliveredById String?

  approvedAt  DateTime?
  shippedAt   DateTime?
  deliveredAt DateTime?

  createdAt DateTime @default(now())

  // ✅ RELATIONS (FIXED NAMES)
  user User? @relation("UserOrders", fields: [userId], references: [id])

  approvedBy  User? @relation("ApprovedBy", fields: [approvedById], references: [id])
  shippedBy   User? @relation("ShippedBy", fields: [shippedById], references: [id])
  deliveredBy User? @relation("DeliveredBy", fields: [deliveredById], references: [id])

  items   OrderItem[]
  events  OrderEvent[]
  address OrderAddress?

  inventoryReservations InventoryReservation[]
  inventoryMovements    InventoryMovement[]

  @@index([userId])
  @@index([status])
  @@index([paymentId])
  @@index([approvedById])
  @@index([shippedById])
  @@index([deliveredById])
  @@index([createdAt])
  @@index([guestEmail])
  @@index([guestName])
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  variantId   String
  quantity    Int
  price       Decimal @db.Decimal(10, 2)
  productName String
  attributes  Json?   @default("[]")

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([variantId])
}

model OrderEvent {
  id        String   @id @default(uuid())
  orderId   String
  type      String
  message   String?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

//////////////////////////////////////////////////////
// INVENTORY SYSTEM
//////////////////////////////////////////////////////

model InventoryReservation {
  id        String            @id @default(uuid())
  variantId String
  orderId   String?
  quantity  Int
  expiresAt DateTime
  status    ReservationStatus
  createdAt DateTime          @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  order   Order?         @relation(fields: [orderId], references: [id])

  @@index([expiresAt])
}

model InventoryMovement {
  id        String                @id @default(uuid())
  variantId String
  change    Int
  type      InventoryMovementType
  reason    String?
  orderId   String?
  createdAt DateTime              @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  order   Order?         @relation(fields: [orderId], references: [id])

  @@index([variantId])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// CART SYSTEM
//////////////////////////////////////////////////////

model Cart {
  id        String   @id @default(uuid())
  userId    String?
  sessionId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  email     String?

  user           User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          CartItem[]
  cartRecoveries CartRecovery[]

  @@index([sessionId])
  @@index([email])
}

model CartItem {
  id        String @id @default(uuid())
  cartId    String
  variantId String
  quantity  Int
  attributes Json? @default("[]")

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([cartId])
}

//////////////////////////////////////////////////////
// STORIES
//////////////////////////////////////////////////////

model Story {
  id         String      @id @default(uuid())
  title      String
  content    String
  image      String?
  category   String?
  userId     String?
  guestEmail String?
  guestName  String?
  createdAt  DateTime    @default(now())
  status     StoryStatus @default(pending)
  likes      Int         @default(0)

  user User? @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

//////////////////////////////////////////////////////
// DONATIONS
//////////////////////////////////////////////////////

model Donation {
  id         String   @id @default(uuid())
  amount     Decimal  @db.Decimal(10, 2)
  email      String
  name       String?
  status     String   @default("pending") // pending, paid, cancelled
  paymentId  String?  @unique // Xendit Invoice ID
  invoiceUrl String?
  userId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}



//////////////////////////////////////////////////////
// AUTH SESSIONS
//////////////////////////////////////////////////////

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  ip        String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

//////////////////////////////////////////////////////
// WEBHOOK EVENTS
//////////////////////////////////////////////////////

model WebhookEvent {
  id        String   @id
  source    String
  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// REVIEWS
//////////////////////////////////////////////////////

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  images    String[]
  createdAt DateTime @default(now())

  userId    String
  productId String

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])

}

//////////////////////////////////////////////////////
// WISHLIST
//////////////////////////////////////////////////////

model Wishlist {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId    String
  productId String

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([userId])
}

model CartRecovery {
  id        String   @id @default(uuid())
  cartId    String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([token])
}

//////////////////////////////////////////////////////
// NOTIFICATIONS
//////////////////////////////////////////////////////

model Notification {
  id        String   @id @default(uuid())
  type      String   // NEW_ORDER, NEW_REVIEW, NEW_STORY, LOW_STOCK
  message   String
  metadata  Json?    // { orderId, reviewId, productId, etc }
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([isRead])
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  admin
  staff
  customer
}

enum OrderStatus {
  initialized
  pending
  approved
  accepted
  paid
  shipped
  delivered
  refunded
  cancelled
}

enum StoryStatus {
  pending
  approved
  rejected
}

enum ReservationStatus {
  reserved
  confirmed
  released
  expired
}

enum InventoryMovementType {
  order
  restock
  adjustment
  reservation
  release
  refund
}

enum ProductStatus {
  active
  draft
  archived
}

enum LoyaltyTier {
  Faith
  Hope
  Love
}
